# =============================================================
#  DIRECTUS + SUPABASE — KONFIGURACJA (.env)
# =============================================================
#  Skopiuj ten plik jako .env i uzupełnij wartości:
#    cp .env.example .env   (Linux/Mac)
#    copy .env.example .env (Windows)
# =============================================================

# -----------------------------------
# 1. KLUCZ BEZPIECZEŃSTWA (WYMAGANY)
# -----------------------------------
# Wygeneruj losowy string min 32 znaki:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET="WKLEJ_TUTAJ_WYGENEROWANY_KLUCZ"

# -----------------------------------
# 2. BAZA DANYCH — SUPABASE POSTGRESQL
# -----------------------------------
# Znajdziesz te dane w:
#   Supabase Dashboard → Twój projekt → Settings → Database
#
DB_CLIENT="pg"
DB_HOST="db.TWOJ-PROJECT-REF.supabase.co"
DB_PORT="5432"
DB_DATABASE="postgres"
DB_USER="postgres"
DB_PASSWORD="TWOJE_HASLO_Z_SUPABASE"
DB_SSL="true"

# -----------------------------------
# 3. KONTO ADMINA DIRECTUS
# -----------------------------------
# Te dane będą użyte do pierwszego logowania do panelu
ADMIN_EMAIL="admin@producktive.pl"
ADMIN_PASSWORD="ZmienNaSilneHaslo123!"

# -----------------------------------
# 4. USTAWIENIA SERWERA
# -----------------------------------
HOST="0.0.0.0"
PORT="8055"
PUBLIC_URL="http://localhost:8055"

# -----------------------------------
# 5. OPCJONALNE — WebSockets (real-time)
# -----------------------------------
WEBSOCKETS_ENABLED="true"

# -----------------------------------
# 6. OPCJONALNE — CORS (dla Nuxt frontend)
# -----------------------------------
CORS_ENABLED="true"
CORS_ORIGIN="http://localhost:3000"

# -----------------------------------
# 7. OPCJONALNE — Uploads / Storage
# -----------------------------------
STORAGE_LOCATIONS="local"
STORAGE_LOCAL_ROOT="./uploads"
